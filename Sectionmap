<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Paly SocSci Section Map</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Sora:wght@300;400;600;700&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --navy: #1B2A4A; --navy2: #2E4370; --accent: #4A90D9; --red: #E63946;
    --bg: #F2F5FB; --surface: #FFFFFF; --border: #D0D8EC; --muted: #7A8BAD;
    --h0: #EBF3FF; --h1: #C0D8F5; --h2: #8BB8EA; --h3: #4A8DD4;
    --h4: #2263B0; --h5: #0D3D73; --h6: #07254A;
    --mono: 'DM Mono', monospace; --sans: 'Sora', sans-serif;
  }
  body { font-family: var(--sans); background: var(--bg); color: var(--navy); min-height: 100vh; }
  .header { background: var(--navy); padding: 20px 32px 18px; display: flex; align-items: baseline; gap: 14px; }
  .header h1 { font-size: 15px; font-weight: 700; color: #fff; letter-spacing: 0.04em; text-transform: uppercase; }
  .header span { font-family: var(--mono); font-size: 11px; color: #7A9BC9; letter-spacing: 0.06em; }
  .drop-zone { margin: 32px auto; max-width: 560px; border: 2px dashed var(--border); border-radius: 12px; padding: 48px 32px; text-align: center; cursor: pointer; transition: border-color 0.2s, background 0.2s; background: var(--surface); }
  .drop-zone:hover, .drop-zone.drag-over { border-color: var(--accent); background: #EEF5FF; }
  .drop-zone .icon { font-size: 36px; margin-bottom: 12px; display: block; }
  .drop-zone h2 { font-size: 15px; font-weight: 600; color: var(--navy); margin-bottom: 6px; }
  .drop-zone p { font-size: 12px; color: var(--muted); }
  .drop-zone input[type=file] { display: none; }
  .btn { display: inline-block; margin-top: 16px; padding: 9px 22px; background: var(--navy); color: #fff; border-radius: 6px; font-family: var(--sans); font-size: 12px; font-weight: 600; letter-spacing: 0.04em; cursor: pointer; border: none; transition: background 0.15s; }
  .btn:hover { background: var(--navy2); }
  #error-msg { max-width: 560px; margin: 0 auto 16px; padding: 10px 16px; background: #FFF0EF; border-left: 3px solid var(--red); border-radius: 4px; font-size: 12px; color: #8B1A1A; display: none; }
  #output { max-width: 1100px; margin: 0 auto 48px; padding: 0 24px; }
  .meta-bar { display: flex; align-items: center; gap: 20px; margin-bottom: 16px; padding: 10px 16px; background: var(--surface); border-radius: 8px; border: 1px solid var(--border); font-size: 12px; color: var(--muted); }
  .meta-bar strong { color: var(--navy); }
  .table-wrap { overflow-x: auto; }
  table { width: 100%; border-collapse: collapse; background: var(--surface); border-radius: 10px; overflow: hidden; box-shadow: 0 2px 12px rgba(27,42,74,0.08); font-size: 13px; }
  thead tr th { background: var(--navy); color: #fff; font-family: var(--mono); font-size: 11px; font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase; padding: 10px 14px; text-align: center; border-right: 1px solid rgba(255,255,255,0.08); }
  thead tr th:first-child { text-align: left; min-width: 190px; }
  thead tr th:last-child { background: var(--navy2); }
  tbody tr { border-bottom: 1px solid var(--border); }
  tbody tr:last-child { border-bottom: none; }
  td { padding: 9px 14px; text-align: center; font-family: var(--mono); font-size: 12px; font-weight: 500; }
  td:first-child { text-align: left; font-family: var(--sans); font-size: 12px; font-weight: 600; color: var(--navy); border-right: 2px solid var(--border); background: var(--surface); padding-left: 16px; }
  td:last-child { font-weight: 700; background: var(--h0) !important; color: var(--navy) !important; border-left: 2px solid var(--border); }
  .heat-0 { background: var(--red); color: #fff; font-size: 14px; }
  .heat-1 { background: var(--h1); color: var(--navy); }
  .heat-2 { background: var(--h2); color: var(--navy); }
  .heat-3 { background: var(--h3); color: #fff; }
  .heat-4 { background: var(--h4); color: #fff; }
  .heat-5, .heat-6 { background: var(--h5); color: #fff; }
  .totals-row td { background: var(--navy2) !important; color: #fff !important; font-weight: 700 !important; font-family: var(--mono) !important; font-size: 12px !important; border-top: 2px solid var(--navy); }
  .totals-row td:first-child { font-family: var(--sans) !important; letter-spacing: 0.04em; text-transform: uppercase; font-size: 10px !important; }
  .gaps-panel { margin-top: 20px; padding: 14px 18px; background: #FFF5F5; border: 1px solid #FFCCCC; border-radius: 8px; }
  .gaps-panel h3 { font-size: 12px; font-weight: 700; color: var(--red); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 10px; }
  .gap-item { display: flex; align-items: baseline; gap: 10px; margin-bottom: 5px; font-size: 12px; }
  .gap-course { font-weight: 700; color: var(--navy); min-width: 190px; font-family: var(--sans); }
  .gap-periods { font-family: var(--mono); color: var(--red); }
  .legend { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 14px; font-size: 11px; align-items: center; }
  .legend-item { display: flex; align-items: center; gap: 6px; }
  .swatch { width: 18px; height: 14px; border-radius: 3px; display: inline-block; }
  .note { margin-top: 16px; font-size: 11px; color: var(--muted); line-height: 1.6; padding: 10px 14px; background: var(--surface); border-radius: 6px; border: 1px solid var(--border); }
  .reset-btn { margin-top: 20px; display: inline-block; padding: 7px 18px; background: transparent; color: var(--muted); border: 1px solid var(--border); border-radius: 6px; font-family: var(--sans); font-size: 11px; cursor: pointer; }
  .reset-btn:hover { border-color: var(--accent); color: var(--accent); }
  @keyframes fadeUp { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }
  #output { animation: fadeUp 0.3s ease; }
</style>
</head>
<body>

<div class="header">
  <h1>Paly Social Science</h1>
  <span>Section Distribution Tool</span>
</div>

<div id="drop-zone" class="drop-zone">
  <span class="icon">📊</span>
  <h2>Drop your Universal Schedule xlsx here</h2>
  <p>Reads the <strong>SocialScience</strong> tab and builds the heat map instantly.<br>Nothing leaves your browser — no uploads, no server.</p>
  <button class="btn" onclick="document.getElementById('file-input').click()">Browse file</button>
  <input type="file" id="file-input" accept=".xlsx,.xls">
</div>

<div id="error-msg"></div>
<div id="output"></div>

<script>
const PERIODS = ["P1","P2","P3","P4","P5","P6","P7"];
const SKIP_CELLS = new Set(["PREP","IL PREP","SJP PREP","Co-Teach PREP","Independent Study","Tech TOSA","","AP Seminar"]);
const SINGLETONS = ["Soc","Sociology","Pos Psych","Positive Psych","Positive Psychology","Mod Cal Hist","Modern CA","US For Pol","US Foreign Policy","Academic Planning","Intro To Gender","Ethnic Studies","BSC","Cont WH"];
const COURSE_MAP = [
  { key: "CA Ethnic Studies 9",  test: c => /CA Ethn(ic)?\s*9/i.test(c) || /CA Ethnic Studies/i.test(c) },
  { key: "World History 9",      test: c => /WH9/i.test(c) || (/Wld Hist/i.test(c) && !/10/.test(c)) },
  { key: "World History 10",     test: c => /Wld Hist\s*10/i.test(c) },
  { key: "US Government",        test: c => /US Govt/i.test(c) && !/SJP/i.test(c) },
  { key: "US History",           test: c => /US Hist/i.test(c) && !/AP/i.test(c) && !/SJP/i.test(c) },
  { key: "AP US History",        test: c => /AP US Hist/i.test(c) || /APUSH/i.test(c) },
  { key: "Econ 11",              test: c => /Econ 11/i.test(c) && !/SJP/i.test(c) },
  { key: "AP Macroeconomics",    test: c => /AP Macro/i.test(c) },
  { key: "AP Psychology",        test: c => /AP Psych/i.test(c) },
  { key: "Psychology",           test: c => /Psych/i.test(c) && !/AP/i.test(c) },
];
const COURSE_ORDER = COURSE_MAP.map(x => x.key);

function isSingleton(c) { return SINGLETONS.some(s => c.toLowerCase().includes(s.toLowerCase())); }
function isSJP(c) { return /SJP/i.test(c); }
function isSkip(raw) {
  const t = raw.trim();
  if (!t) return true;
  if (SKIP_CELLS.has(t)) return true;
  if (t.startsWith("Teacher Advisor") || t.startsWith("Study Hall") || t.startsWith("Independent Study") || /AP Seminar/i.test(t)) return true;
  return false;
}
function parseCellToCourses(raw) {
  if (!raw) return [];
  const t = String(raw).trim();
  if (isSkip(t)) return [];
  return (t.includes("/") ? t.split("/").map(x => x.trim()) : [t]).filter(p => p && !isSkip(p) && !/AP Seminar/i.test(p));
}
function categorizeCourse(course) {
  if (isSJP(course) || isSingleton(course)) return null;
  for (const { key, test } of COURSE_MAP) { if (test(course)) return key; }
  return null;
}

function parseSheet(ws) {
  const range = XLSX.utils.decode_range(ws['!ref']);
  let headerRow = -1, teacherCol = -1, periodCols = {};
  for (let R = range.s.r; R <= Math.min(range.e.r, 5); R++) {
    for (let C = range.s.c; C <= range.e.c; C++) {
      const cell = ws[XLSX.utils.encode_cell({r:R,c:C})];
      if (!cell) continue;
      const val = String(cell.v||"").trim();
      if (val === "Teacher") { headerRow = R; teacherCol = C; }
      const pm = val.match(/^Period\s*(\d)$/i);
      if (pm) periodCols["P"+pm[1]] = C;
    }
  }
  if (headerRow === -1) throw new Error("Could not find teacher schedule header row. Is this the SocialScience tab?");
  if (Object.keys(periodCols).length < 7) throw new Error(`Only found ${Object.keys(periodCols).length}/7 period columns.`);

  const dist = {};
  for (const c of COURSE_ORDER) dist[c] = {P1:0,P2:0,P3:0,P4:0,P5:0,P6:0,P7:0};

  let teacherCount = 0;
  for (let R = headerRow+1; R <= range.e.r; R++) {
    const tCell = ws[XLSX.utils.encode_cell({r:R,c:teacherCol})];
    if (!tCell || !tCell.v) continue;
    const teacher = String(tCell.v).trim();
    if (!teacher || /^(FTE|Total|Poux|Tari)$/i.test(teacher)) continue;
    teacherCount++;
    for (const [period, col] of Object.entries(periodCols)) {
      const cell = ws[XLSX.utils.encode_cell({r:R,c:col})];
      const raw = cell ? String(cell.v||"").trim() : "";
      for (const course of parseCellToCourses(raw)) {
        const cat = categorizeCourse(course);
        if (cat && dist[cat]) dist[cat][period]++;
      }
    }
  }
  return { dist, teacherCount };
}

function heatClass(v) {
  if (v===0) return "heat-0";
  if (v===1) return "heat-1";
  if (v===2) return "heat-2";
  if (v===3) return "heat-3";
  if (v===4) return "heat-4";
  return "heat-5";
}

function render(data, filename) {
  const { dist, teacherCount } = data;
  const gaps = [];
  const periodTotals = {P1:0,P2:0,P3:0,P4:0,P5:0,P6:0,P7:0};

  let rows = "";
  for (const course of COURSE_ORDER) {
    const row = dist[course];
    const total = PERIODS.reduce((s,p) => s+row[p], 0);
    const zeroPeriods = PERIODS.filter(p => row[p]===0);
    if (zeroPeriods.length) gaps.push({course, periods: zeroPeriods});
    PERIODS.forEach(p => periodTotals[p] += row[p]);
    rows += `<tr><td>${course}</td>${PERIODS.map(p=>`<td class="${heatClass(row[p])}">${row[p]===0?"✕":row[p]}</td>`).join("")}<td>${total}</td></tr>`;
  }

  const grandTotal = PERIODS.reduce((s,p) => s+periodTotals[p], 0);
  const totalsRow = `<tr class="totals-row"><td>Total / Period</td>${PERIODS.map(p=>`<td>${periodTotals[p]}</td>`).join("")}<td>${grandTotal}</td></tr>`;

  let gapsHtml = "";
  if (gaps.length) {
    gapsHtml = `<div class="gaps-panel"><h3>⚠ Coverage Gaps — Zero Sections</h3>${gaps.map(g=>`<div class="gap-item"><span class="gap-course">${g.course}</span><span class="gap-periods">${g.periods.join(", ")}</span></div>`).join("")}</div>`;
  }

  document.getElementById("output").innerHTML = `
    <div class="meta-bar">
      <span>File: <strong>${filename}</strong></span>
      <span>Teachers parsed: <strong>${teacherCount}</strong></span>
      <span style="margin-left:auto;color:#4A90D9;font-weight:600;font-size:11px;">SJP &amp; singletons excluded</span>
    </div>
    <div class="table-wrap"><table>
      <thead><tr><th>Course</th>${PERIODS.map(p=>`<th>${p}</th>`).join("")}<th>Total</th></tr></thead>
      <tbody>${rows}${totalsRow}</tbody>
    </table></div>
    <div class="legend">
      <strong style="font-size:11px;color:var(--muted);">Intensity:</strong>
      <div class="legend-item"><span class="swatch" style="background:#E63946"></span> 0 (gap)</div>
      <div class="legend-item"><span class="swatch" style="background:#C0D8F5"></span> 1</div>
      <div class="legend-item"><span class="swatch" style="background:#8BB8EA"></span> 2</div>
      <div class="legend-item"><span class="swatch" style="background:#4A8DD4"></span> 3</div>
      <div class="legend-item"><span class="swatch" style="background:#2263B0"></span> 4</div>
      <div class="legend-item"><span class="swatch" style="background:#0D3D73"></span> 5+</div>
    </div>
    ${gapsHtml}
    <div class="note"><strong>Notes:</strong> SJP variants excluded (run P5–P6 by design). Singletons excluded (Sociology, Positive Psych, US Foreign Policy, Modern CA History, Intro to Gender Studies). AP Seminar excluded (CTE dept). CA Ethnic Studies 9 and World History 9 always match — same seat, different semesters. Same for US Government / World History 10.</div>
    <button class="reset-btn" onclick="location.reload()">↩ Load another file</button>
  `;
  document.getElementById("drop-zone").style.display = "none";
}

function handleFile(file) {
  const errEl = document.getElementById("error-msg");
  errEl.style.display = "none";
  const reader = new FileReader();
  reader.onload = e => {
    try {
      const wb = XLSX.read(new Uint8Array(e.target.result), {type:"array"});
      const sheetName = wb.SheetNames.find(n => /socialscience/i.test(n.replace(/\s/g,"")));
      if (!sheetName) throw new Error(`No "SocialScience" tab found. Tabs in this file: ${wb.SheetNames.join(", ")}`);
      render(parseSheet(wb.Sheets[sheetName]), file.name);
    } catch(err) {
      errEl.textContent = "Error: " + err.message;
      errEl.style.display = "block";
    }
  };
  reader.readAsArrayBuffer(file);
}

const dz = document.getElementById("drop-zone");
dz.addEventListener("dragover", e => { e.preventDefault(); dz.classList.add("drag-over"); });
dz.addEventListener("dragleave", () => dz.classList.remove("drag-over"));
dz.addEventListener("drop", e => { e.preventDefault(); dz.classList.remove("drag-over"); if(e.dataTransfer.files[0]) handleFile(e.dataTransfer.files[0]); });
document.getElementById("file-input").addEventListener("change", e => { if(e.target.files[0]) handleFile(e.target.files[0]); });
</script>
</body>
</html>
